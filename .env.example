# Home base
HOME_POSTCODE=DN22 0QG

# John Pye: hammer × 1.5 = invoice (25% + VAT buyer premium)
JOHN_PYE_BUYER_MULTIPLIER=1.5

# Collection fuel (pence per mile, round trip calculated automatically)
FUEL_PENCE_PER_MILE=13

# eBay seller fees (excludes shipping charged to buyer)
EBAY_FEE_RATE=0.13

# Minimum net profit margin on total buy cost
MIN_NET_PROFIT_RATE=0.35

# Only show lots ending within this many hours
AUCTION_ENDING_WITHIN_HOURS=24

# Outbound shipping tiers (GBP)
SHIP_UNDER_5KG=4.99
SHIP_5_TO_30KG=13.61
SHIP_OVER_30KG=49.99

# Insurance placeholder — not yet in profit calc Phase 1
# INSURANCE_PER_HOUR=0

PORT=3003

# Phase 2: path to exported John Pye listings JSON
# JOHNPYE_LISTINGS_JSON=./data/my-listings.json
